{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/revyr/intake-package.schema.json",
  "title": "REVYR Intake Package Schema",
  "description": "IN DIESEM LAUF NEU VERFASSTES SCHEMA (2026-07-19). Es ist KEIN vorbestehender, extern definierter Standard und war vor diesem Lauf im Repository nicht vorhanden. Die Aussage 'Schema valid' bedeutet ausschliesslich: die Datei intake-package.json entspricht DIESEM hier definierten Schema. Sie bedeutet NICHT, dass ein anerkannter Intake-Standard erfuellt waere, und sie bestaetigt keinen Inhalt.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_provenance",
    "feature_slug",
    "generated_at",
    "confirmation",
    "artifacts",
    "id_counts",
    "requirements",
    "nfrs",
    "open_questions",
    "contradictions",
    "contra_006_criterion",
    "validation",
    "blockers",
    "overall_status"
  ],
  "properties": {
    "schema_provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_file",
        "authored_in_this_run",
        "is_preexisting_standard",
        "validator_file",
        "note"
      ],
      "properties": {
        "schema_file": {
          "type": "string"
        },
        "authored_in_this_run": {
          "const": true
        },
        "is_preexisting_standard": {
          "const": false
        },
        "validator_file": {
          "type": "string"
        },
        "note": {
          "type": "string",
          "minLength": 40
        }
      }
    },
    "feature_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "generated_at": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "user_confirmed",
        "true_line_status",
        "self_certified",
        "max_reachable_status"
      ],
      "properties": {
        "user_confirmed": {
          "const": false
        },
        "true_line_status": {
          "const": "pending-watcher"
        },
        "self_certified": {
          "const": false
        },
        "max_reachable_status": {
          "const": "READY_FOR_USER_CONFIRMATION"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "role",
          "exists",
          "lines",
          "declared_status"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "exists": {
            "type": "boolean"
          },
          "lines": {
            "type": "integer",
            "minimum": 0
          },
          "declared_status": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "id_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "by_prefix",
        "unmanaged_prefixes",
        "template_placeholders"
      ],
      "properties": {
        "by_prefix": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "total"
            ],
            "properties": {
              "active": {
                "type": "integer",
                "minimum": 0
              },
              "deprecated": {
                "type": "integer",
                "minimum": 0
              },
              "reserved": {
                "type": "integer",
                "minimum": 0
              },
              "template-placeholder": {
                "type": "integer",
                "minimum": 0
              },
              "open": {
                "type": "integer",
                "minimum": 0
              },
              "resolved": {
                "type": "integer",
                "minimum": 0
              },
              "total": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        },
        "unmanaged_prefixes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "prefix",
              "registry_managed",
              "risk"
            ],
            "properties": {
              "prefix": {
                "type": "string"
              },
              "registry_managed": {
                "const": false
              },
              "risk": {
                "type": "string"
              }
            }
          }
        },
        "template_placeholders": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z]+-\\d{3}$"
          }
        }
      }
    },
    "requirements": {
      "description": "KEINE feste Anzahl. Die Zahl aktiver Requirements wird aus docs/ID-REGISTRY.md abgeleitet; ein Schema, das sie festschreibt, schlaegt nach jeder legitimen Bestandsaenderung fehl, ohne dass etwas defekt ist. Frueher stand hier minItems/maxItems 36.",
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "measurement_type",
          "release_gate",
          "source_type",
          "source_provenance",
          "owner_status",
          "trace_id",
          "acceptance_criterion",
          "evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^REQ-\\d{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "measurement_type_verbatim": {
            "description": "Der ungekuerzte PRD-Wortlaut. `measurement_type` traegt das fuehrende Vokabeltoken; Zusaetze wie '(im bestehenden Modell: FUNCTIONAL CONTROL)' bleiben hier erhalten und werden NICHT wegnormiert.",
            "type": "string",
            "minLength": 1
          },
          "measurement_type": {
            "enum": [
              "OPERATIONAL_QUALITY",
              "COMPLIANCE_CONTROL",
              "RESEARCH_HYPOTHESIS",
              "PRODUCT_OUTCOME"
            ]
          },
          "release_gate": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "description": "Nur die Kopfklasse. Der maschinenlesbare Herkunftsvorbehalt steht in source_provenance und MUSS mitgelesen werden: ein blosses 'EXPLICIT' hier bedeutet NICHT belegte Herkunft.",
            "enum": [
              "EXPLICIT",
              "ASSUMPTION",
              "MISSING",
              "BLOCKER",
              "CONTRADICTION"
            ]
          },
          "source_provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "source_type",
              "source_type_verbatim",
              "evidence_backed",
              "clause_limited",
              "cited_sources",
              "caveat",
              "user_confirmed"
            ],
            "properties": {
              "source_type": {
                "enum": [
                  "EXPLICIT",
                  "ASSUMPTION",
                  "MISSING",
                  "BLOCKER",
                  "CONTRADICTION"
                ]
              },
              "source_type_verbatim": {
                "type": "string",
                "minLength": 1
              },
              "evidence_backed": {
                "type": "boolean"
              },
              "clause_limited": {
                "type": "boolean"
              },
              "cited_sources": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "caveat": {
                "type": "string",
                "minLength": 20
              },
              "user_confirmed": {
                "const": false
              }
            }
          },
          "owner_status": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "resolved",
              "marker"
            ],
            "properties": {
              "resolved": {
                "type": "boolean"
              },
              "marker": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "trace_id": {
            "type": "string",
            "pattern": "^TRC-\\d{3}$"
          },
          "acceptance_criterion": {
            "type": "string",
            "pattern": "^AC-\\d{3}$"
          },
          "evidence": {
            "type": "string",
            "pattern": "^EV-\\d{3}$"
          },
          "has_research_plan": {
            "type": "boolean"
          }
        }
      }
    },
    "nfrs": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "source_type",
          "evidence_status",
          "measurement_method",
          "owner_status",
          "release_gate"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^NFR-\\d{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "enum": [
              "EXPLICIT",
              "ASSUMPTION",
              "MISSING",
              "BLOCKER",
              "CONTRADICTION"
            ]
          },
          "source_type_verbatim": {
            "type": "string"
          },
          "target_or_pass_condition": {
            "type": "string"
          },
          "source_of_target": {
            "type": "string"
          },
          "evidence_status": {
            "description": "verified ist hier ausgeschlossen: es existiert kein Code, kein Build und kein Geraetetest. MISSING ist zugelassen und heisst: das PRD fuehrt fuer dieses NFR ueberhaupt kein evidence_status-Feld. Das Schema darf das nicht verbieten — sonst muesste ein Wert erfunden oder die Luecke verschwiegen werden. Der Befund bleibt sichtbar (Check C9).",
            "enum": [
              "not-required",
              "not-planned",
              "planned",
              "pending",
              "failed",
              "blocked",
              "MISSING"
            ]
          },
          "evidence_status_verbatim": {
            "type": "string"
          },
          "evidence_status_qualified": {
            "description": "true = der Wert ist im PRD klauselbeschraenkt formuliert. Die Einschraenkung steht im Verbatim und darf nicht wegnormiert werden.",
            "type": "boolean"
          },
          "measurement_method": {
            "description": "Leer zulaessig, wenn das PRD keine Mess-/Kontrollmethode fuehrt (NFR-008). Die Luecke wird von Check C9 als NICHT ERFUELLT gemeldet, statt sie hier durch einen erfundenen Wert zu schliessen.",
            "type": "string"
          },
          "measurement_window": {
            "type": "string"
          },
          "reference_environment": {
            "type": "string"
          },
          "evidence_source": {
            "type": "string"
          },
          "release_gate": {
            "type": "string",
            "minLength": 1
          },
          "owner_status": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "resolved",
              "marker"
            ],
            "properties": {
              "resolved": {
                "type": "boolean"
              },
              "marker": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "blocking_verbatim": {
            "type": "string"
          }
        }
      }
    },
    "contra_006_criterion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "criterion",
        "statements",
        "keine_ungueltigen_registry_statuswerte",
        "wortlaut",
        "nicht_behauptet",
        "decision_reference_missing"
      ],
      "properties": {
        "criterion": {
          "type": "string",
          "minLength": 20
        },
        "statements": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "nr",
              "aussage",
              "erfuellt"
            ],
            "properties": {
              "nr": {
                "type": "integer",
                "minimum": 1
              },
              "aussage": {
                "type": "string",
                "minLength": 1
              },
              "erfuellt": {
                "type": "boolean"
              },
              "ableitung": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "quelle": {
                "type": "string"
              }
            }
          }
        },
        "keine_ungueltigen_registry_statuswerte": {
          "type": "boolean"
        },
        "wortlaut": {
          "type": "string",
          "minLength": 20
        },
        "nicht_behauptet": {
          "type": "string",
          "minLength": 20
        },
        "decision_reference_missing": {
          "type": "string",
          "minLength": 20
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^OQ-\\d{3}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "open",
              "resolved"
            ]
          },
          "owner": {
            "type": "string"
          },
          "due": {
            "type": "string"
          },
          "default_if_unresolved": {
            "type": "string"
          }
        }
      }
    },
    "contradictions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "registry_status",
          "ledger_status",
          "blocking"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^CONTRA-\\d{3}$"
          },
          "registry_status": {
            "enum": [
              "open",
              "resolved"
            ]
          },
          "ledger_status": {
            "type": "string",
            "minLength": 1
          },
          "blocking": {
            "description": "ABGELEITET nach Registry §3.1 (derive_blocking). Nie je ID hartkodiert. Die Herleitung steht in status_model.blocking_derivation.",
            "type": "boolean"
          },
          "divergence": {
            "type": "boolean"
          },
          "status_model": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "resolution_status",
              "evidence_status",
              "blocked_gates",
              "blocked_activities",
              "evidence_gate",
              "blocking_derivation",
              "outcome"
            ],
            "properties": {
              "resolution_status": {
                "type": "string",
                "minLength": 1
              },
              "evidence_status": {
                "type": "string",
                "minLength": 1
              },
              "blocked_gates": {
                "description": "C16: NUR Release-Gates. Ein Taetigkeitsbezeichner hier ist ein Fehler, kein Sonderfall.",
                "type": "array",
                "items": {
                  "enum": [
                    "P0",
                    "A0",
                    "A1",
                    "A2",
                    "B",
                    "C",
                    "D",
                    "E"
                  ]
                }
              },
              "blocked_activities": {
                "description": "C16: NUR Taetigkeiten. Ein Gate-Bezeichner hier ist ein Fehler. Die beiden Wertebereiche sind disjunkt; das frueher gemeinsame Feld blocking_scope ist ersatzlos entfallen.",
                "type": "array",
                "items": {
                  "enum": [
                    "documentation",
                    "planning",
                    "implementation",
                    "field-test",
                    "release",
                    "store-submission",
                    "database-schema-finalization",
                    "account-release",
                    "competition-release",
                    "territory-release"
                  ]
                }
              },
              "evidence_gate": {
                "type": "string",
                "minLength": 1
              },
              "blocking_derivation": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "outcome": {
                "description": "Die sechs Ergebnisklassen, die der Validator unterscheiden koennen muss.",
                "enum": [
                  "1-designentscheidung-offen",
                  "2-entschieden-evidence-ausstehend",
                  "3-entschieden-evidence-fehlgeschlagen",
                  "4-vollstaendig",
                  "5-nicht-blockierend-fuers-aktuelle-gate",
                  "6-blockierend-fuers-aktuelle-gate"
                ]
              },
              "decision_reference": {
                "type": "string"
              },
              "evidence_reference": {
                "type": "string"
              }
            }
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator",
        "authored_in_this_run",
        "checks_total",
        "checks_passed",
        "checks_failed",
        "overall",
        "failed_check_ids"
      ],
      "properties": {
        "validator": {
          "type": "string"
        },
        "authored_in_this_run": {
          "const": true
        },
        "checks_total": {
          "type": "integer",
          "minimum": 1
        },
        "checks_passed": {
          "type": "integer",
          "minimum": 0
        },
        "checks_failed": {
          "type": "integer",
          "minimum": 0
        },
        "overall": {
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "failed_check_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "run_date": {
          "type": "string"
        },
        "run_scope": {
          "type": "string"
        },
        "delta_to_previous_run": {
          "type": "object"
        },
        "failed_check_diagnosis": {
          "type": "object",
          "description": "Je fehlgeschlagener Pruefung: Art des Befunds (Dokumentdefekt | Validator-Limitation | strukturell unerreichbar), Owner, Begruendung. Eine Diagnose HEBT DEN FEHLSCHLAG NICHT AUF."
        },
        "other_validators": {
          "type": "array",
          "items": {
            "type": "object"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "kind",
          "summary",
          "affects",
          "decided_by"
        ],
        "properties": {
          "kind": {
            "enum": [
              "BLOCKER",
              "MISSING",
              "ASSUMPTION",
              "OPEN QUESTION",
              "CONTRADICTION"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "affects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "decided_by": {
            "type": "string"
          }
        }
      }
    },
    "overall_status": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "gate_ready",
        "reason"
      ],
      "properties": {
        "value": {
          "description": "READY_FOR_AGILETEAM_PLANNING ist ausgeschlossen und darf auch nach Behebung aller Checks nicht von einem Agenten gesetzt werden. Solange die zehn Canvas-Items unbestaetigt sind, gilt BLOCKED_TRACEABILITY.",
          "enum": [
            "BLOCKED_TRACEABILITY",
            "READY_FOR_USER_CONFIRMATION"
          ]
        },
        "gate_ready": {
          "const": false
        },
        "reason": {
          "type": "string",
          "minLength": 40
        }
      }
    },
    "tooling_freeze": {
      "type": "object",
      "description": "Freeze-Vermerk fuer Metamodell und Validatoren. location_caveat ist Pflicht, weil die Werkzeuge im Scratchpad und nicht im Repository liegen.",
      "required": [
        "frozen_on",
        "scope",
        "location_caveat",
        "unfreeze_requires"
      ],
      "properties": {
        "frozen_on": {
          "type": "string"
        },
        "scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "location_caveat": {
          "type": "string"
        },
        "unfreeze_requires": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "not_frozen": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "x_schema_change_log": [
    {
      "date": "2026-07-20",
      "change": "ADDITIV: validation.{run_date,run_scope,delta_to_previous_run,failed_check_diagnosis,other_validators} und root.tooling_freeze aufgenommen.",
      "reason": "Die Instanz musste die ECHTE Ausgabe des Laufs vom 2026-07-20 tragen (32/38, 6 Fehlschlaege inkl. C2) sowie den Freeze-Vermerk. Ohne diese Erweiterung waere die Datei nur schemakonform geblieben, indem sie den veralteten Stand 33/5 weitergefuehrt haette.",
      "nature": "Keine bestehende Regel gelockert, kein Feld entfernt, kein Vokabular geaendert, kein Pflichtfeld optional gemacht. Letzte Aenderung vor dem Freeze."
    }
  ]
}